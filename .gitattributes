# Windows core.autocrlf=true 환경에서 CRLF 변환과 한국어(UTF-8) 파일 수정이 겹쳐
# 발생하던 파일 손상을 막기 위한 설정. 텍스트 파일 개행을 LF로 고정한다.
# 참고: PROJECT_EVALUATION_REPORT.html #06 구조적 한계, #07 로드맵 Critical 항목.

# 기본: 텍스트로 자동 판별되는 파일은 커밋 시 LF로 정규화
* text=auto

# 파이썬 소스: 항상 LF 유지
*.py text eol=lf

# 문서/설정 파일도 LF로 통일
*.md text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.env text eol=lf
*.txt text eol=lf
*.gitattributes text eol=lf
*.gitignore text eol=lf

# Windows 전용 스크립트는 CRLF 유지
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# 바이너리: 개행 변환 금지
*.db binary
*.sqlite binary
*.sqlite3 binary
*.png binary
*.jpg binary
*.jpeg binary
*.pdf binary
*.docx binary
