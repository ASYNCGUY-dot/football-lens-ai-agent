# =============================================
# week3 .env.example
# Football Lens 환경변수 설정
# =============================================
# 사용법: 이 파일을 .env 로 복사한 뒤 실제 값을 입력하세요
#   cp .env.example .env

# ── week1/2에서 이어받은 설정 ──────────────────
NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret
FOOTBALL_DATA_API_KEY=your_football_data_api_key

DB_HOST=localhost
DB_PORT=5432
DB_NAME=football_lens
DB_USER=postgres
DB_PASSWORD=your_db_password

ANTHROPIC_API_KEY=your_anthropic_api_key
OPENAI_API_KEY=your_openai_api_key
GOOGLE_API_KEY=your_google_api_key

# ── week3 신규 설정 ─────────────────────────────

# [ChromaDB] 벡터 DB 저장 경로 (로컬 파일)
CHROMA_PERSIST_DIR=./chroma_db

# [임베딩 모델] sentence-transformers 모델명
# 권장: all-MiniLM-L6-v2 (경량·다국어 지원)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# [이메일 SMTP 설정] ─────────────────────────────
# Gmail 사용 시:
#   - Gmail → 구글 계정 → 보안 → 앱 비밀번호 발급 필요
#   - SMTP_HOST=smtp.gmail.com
#   - SMTP_PORT=587
#
# 네이버 메일 사용 시:
#   - 네이버 메일 → 환경설정 → POP3/IMAP 설정 → SMTP 사용 허용
#   - SMTP_HOST=smtp.naver.com
#   - SMTP_PORT=465
#   - SMTP_USE_SSL=true

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_SSL=false          # TLS: false (587), SSL: true (465)
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# 이메일 수신자 (쉼표로 여러 명 지정 가능)
EMAIL_RECIPIENTS=recipient1@example.com,recipient2@example.com
# 발신자 이름 (선택)
EMAIL_SENDER_NAME=Football Lens Bot
